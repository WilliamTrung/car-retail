# Docker Compose deploy metadata — copy to ~/dev/shared/car-retail/secrets/deploy.env
# Usage: deploy car-retail   (or: docker compose --env-file ~/dev/shared/car-retail/secrets/deploy.env up -d --build)

COMPOSE_PROJECT_NAME=car-retail

# Path to app runtime secrets (external to repo; local dev defaults to web/.env)
APP_ENV_FILE=~/dev/shared/car-retail/secrets/app/.env

# Build-time DATABASE_URL (compose build uses network: host → use localhost if Postgres is on host :5432)
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/car_retail
# Build-time public URL (baked into Next.js client bundle)
NEXT_PUBLIC_SITE_URL=https://car-retail.example.com
# Runtime DATABASE_URL lives in APP_ENV_FILE — use postgres on db-net (shared-postgres alias)

# Optional: image tag override
# IMAGE_TAG=latest
