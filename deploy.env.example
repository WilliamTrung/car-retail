# Docker Compose deploy metadata — copy to ~/prod/shared/car-retail/secrets/deploy.env
# Usage: docker compose --env-file ~/prod/shared/car-retail/secrets/deploy.env up -d --build

COMPOSE_PROJECT_NAME=car-retail

# Path to app runtime secrets (external to repo; local dev defaults to web/.env)
APP_ENV_FILE=~/prod/shared/car-retail/secrets/app/.env

# Used for docker compose build arg interpolation (must match app DATABASE_URL)
DATABASE_URL=postgresql://postgres:PASSWORD@shared-postgres:5432/car_retail

# Optional: image tag override
# IMAGE_TAG=latest
