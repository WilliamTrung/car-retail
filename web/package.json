{
  "name": "car-retail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:mock": "node prisma/seed-mock.js",
    "db:seed:scraped": "node prisma/seed-bootstrap.js && node prisma/seed-scraped.js",
    "db:seed:media": "node prisma/seed-media.js",
    "db:seed:media:reference": "tsx scripts/seed-media-reference.js",
    "db:reset": "tsx scripts/reset-all.js",
    "db:reseed": "tsx scripts/reset-all.js --purge && npm run db:seed:scraped && npm run db:seed:media -- --purge",
    "start:standalone": "node scripts/start-standalone.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.9.1",
    "@aws-sdk/client-s3": "^3.758.0",
    "@prisma/client": "^6.5.0",
    "@swc/helpers": "0.5.23",
    "next": "^15.2.4",
    "next-auth": "^5.0.0-beta.25",
    "next-intl": "^4.0.2",
    "pino": "^9.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "chrome-launcher": "^1.1.2",
    "lighthouse": "^12.4.0",
    "playwright": "^1.51.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
