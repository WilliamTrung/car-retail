# PostgreSQL (external — not in Compose)
DATABASE_URL=postgresql://user:password@localhost:5432/car_retail

# Auth.js v5 (≥16 characters)
AUTH_SECRET=change-me-to-a-long-random-secret

# Cloudflare R2 (S3-compatible)
STORAGE_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_S3_REGION=auto
STORAGE_S3_BUCKET=car-retail-media
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_PUBLIC_URL=https://media.example.com
STORAGE_S3_USE_SSL=true

# App
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Prisma seed only (≥12 characters)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-long
